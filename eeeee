local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ChestRemoteEvent = ReplicatedStorage:WaitForChild("Event"):WaitForChild("Backpack"):WaitForChild("ChestRemoteEvent")
local BackpackRemoteFunction = ReplicatedStorage:WaitForChild("Event"):WaitForChild("Backpack"):WaitForChild("BackpackRemoteFunction")

local ChestFolder = workspace["\229\174\157\231\174\177"] -- Папка "宝物"
local SafeName = "\228\191\157\233\153\169\231\174\177"    -- Сейф "密码箱"

local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

local currentTargetChestId = nil 
local chestOpenedSuccessfully = false

-- УШИ
ChestRemoteEvent.OnClientEvent:Connect(function(action, data)
    if not data or not data.chestId then return end
    if data.chestId ~= currentTargetChestId then return end

    if action == "RequestSafePassword" then
        pcall(function() BackpackRemoteFunction:InvokeServer("CloseChest") end)
        currentTargetChestId = nil
        return
    end

    if action == "OpenChest" then
        print("Сундук открыт! Забираю лут...")
        chestOpenedSuccessfully = true
        task.wait(0.3)

        for _, item in ipairs(data.items or {}) do
            if item.id then
                print(" -> Забрал:", item.name or "Неизвестно")
                pcall(function()
                    BackpackRemoteFunction:InvokeServer("TakeChestItem", data.chestId, item.id, "MyBackpackInventory")
                end)
                task.wait(0.1)
            end
        end
        
        task.wait(0.2)
        pcall(function() BackpackRemoteFunction:InvokeServer("CloseChest") end)
        currentTargetChestId = nil
    end
end)

-- ОСНОВНОЙ ЦИКЛ ФАРМА
print("Запуск фермера...")

for _, obj in ipairs(ChestFolder:GetChildren()) do
    
    if obj:IsA("Model") and obj.Name ~= SafeName then 
        
        local chestId = obj:GetAttribute("ChestId")
        
        if chestId then
            currentTargetChestId = chestId
            chestOpenedSuccessfully = false
            
            -- 1. Телепортируемся
            local targetCFrame = obj:GetPivot()
            HumanoidRootPart.CFrame = targetCFrame * CFrame.new(0, 5, 0)
            task.wait(0.5) 
            
            -- 2. АВТОМАТИЧЕСКОЕ НАЖАТИЕ КНОПКИ
            local interacted = false
            
            -- Ищем кнопку "Нажми E" (ProximityPrompt)
            local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
            if prompt then
                print("Нажимаю кнопку взаимодействия (E)...")
                firesignal(prompt.Triggered)
                interacted = true
            end
            
            -- Если кнопки E нет, ищем кликабельность мышкой (ClickDetector)
            if not interacted then
                for _, v in ipairs(obj:GetDescendants()) do
                    if v:IsA("ClickDetector") then
                        print("Кликаю по сундуку мышкой...")
                        firesignal(v.MouseClick)
                        interacted = true
                        break
                    end
                end
            end
            
            if not interacted then
                print("Кнопка не найдена, жду автооткрытия...")
            end
            
            -- 3. Ждем реакции сервера
            local waitTime = 0
            while currentTargetChestId ~= nil and waitTime < 3 do
                task.wait(0.1)
                waitTime = waitTime + 0.1
            end
            
            if not chestOpenedSuccessfully then
                warn("Сундук не открылся.")
                currentTargetChestId = nil
            end
            
            task.wait(0.5)
        end
    end
end

print("Фарм завершен!")
