local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ChestRemoteEvent = ReplicatedStorage:WaitForChild("Event"):WaitForChild("Backpack"):WaitForChild("ChestRemoteEvent")
local BackpackRemoteFunction = ReplicatedStorage:WaitForChild("Event"):WaitForChild("Backpack"):WaitForChild("BackpackRemoteFunction")

local ChestFolder = workspace:FindFirstChild("宝箱") or workspace["\229\174\157\231\174\177"]
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

-- Переменная, чтобы скрипт знал, к какому сундуку мы currently подошли
local currentTargetChestId = nil 
local chestOpenedSuccessfully = false

-- СОЗДАЕМ "УШИ", КОТОРЫЕ СЛУШАЮТ СЕРВЕР
-- Когда сервер видит нас рядом с сундуком, он сам вызовет это событие
ChestRemoteEvent.OnClientEvent:Connect(function(action, data)
    -- Если сервер прислал сигнал "OpenChest" и это именно тот сундук, к которому мы только что телепортировались
    if action == "OpenChest" and data and data.chestId == currentTargetChestId then
        print("Сервер открыл сундук! Нахожу предметы...")
        chestOpenedSuccessfully = true
        
        task.wait(0.3) -- Небольшая пауза, чтобы клиент успел отрисовать интерфейс

        -- Перебираем все предметы, которые прислал сервер
        for _, item in ipairs(data.items or {}) do
            if item.id then
                print("Забираю предмет:", item.name or "Неизвестно")
                
                -- Отправляем на сервер команду ЗАБРАТЬ ПРЕДМЕТ (как при ручном клике)
                pcall(function()
                    BackpackRemoteFunction:InvokeServer("TakeChestItem", data.chestId, item.id, "MyBackpackInventory")
                end)
                task.wait(0.1) -- Пауза между взятием предметов, чтобы не словить ошибку
            end
        end
        
        task.wait(0.2)
        
        -- Закрываем сундук
        print("Закрываю сундук.")
        pcall(function()
            BackpackRemoteFunction:InvokeServer("CloseChest")
        end)
        
        -- Сбрасываем цель
        currentTargetChestId = nil
    end
end)

-- ОСНОВНОЙ ЦИКЛ ФАРМА
print("Начинаем фарм. Найдено сундуков:", #ChestFolder:GetChildren())

for _, chestModel in ipairs(ChestFolder:GetChildren()) do
    if chestModel:IsA("Model") and chestModel.Name == "保险箱" then 
        local chestId = chestModel:GetAttribute("ChestId")
        local rootPart = chestModel.PrimaryPart
        
        if chestId and rootPart then
            -- Подготавливаем переменные для "ушей"
            currentTargetChestId = chestId
            chestOpenedSuccessfully = false
            
            -- Телепортируемся
            HumanoidRootPart.CFrame = rootPart.CFrame * CFrame.new(0, 5, 0)
            
            -- ЖДЕМ, пока сервер среагирует на наше присутствие и откроет сундук (максимум 3 секунды)
            local waitTime = 0
            while currentTargetChestId ~= nil and waitTime < 3 do
                task.wait(0.1)
                waitTime = waitTime + 0.1
            end
            
            if not chestOpenedSuccessfully then
                warn("Сервер не открыл сундук (возможно он пуст или слишком далеко). Пропускаем.")
                currentTargetChestId = nil
            end
            
            task.wait(0.5) -- Пауза перед переходом к следующему сундуку
        end
    end
end

print("Все сундуки обработаны! Фарм завершен.")
