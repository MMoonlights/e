local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ChestRemoteEvent = ReplicatedStorage:WaitForChild("Event"):WaitForChild("Backpack"):WaitForChild("ChestRemoteEvent")
local BackpackRemoteFunction = ReplicatedStorage:WaitForChild("Event"):WaitForChild("Backpack"):WaitForChild("BackpackRemoteFunction")

local ChestFolder = workspace:FindFirstChild("宝箱") or workspace["\229\174\157\231\174\177"]
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

-- Переменные состояния
local currentTargetChestId = nil 
local chestOpenedSuccessfully = false
local skippedPasswordChest = false

-- УШИ: Слушаем ВСЕ сигналы от сервера про сундуки
ChestRemoteEvent.OnClientEvent:Connect(function(action, data)
    -- Защита от ошибок, если data пустая
    if not data or not data.chestId then return end
    
    -- Если это не тот сундук, к которому мы сейчас пошли - игнорируем
    if data.chestId ~= currentTargetChestId then return end

    -- СИТУАЦИЯ 1: Сервер прислал запрос на пароль
    if action == "RequestSafePassword" then
        warn("Попался сундук с паролем! Закрываем и скипаем.")
        skippedPasswordChest = true
        
        -- Пытаемся закрыть (на всякий случай, чтобы не завис интерфейс)
        pcall(function()
            BackpackRemoteFunction:InvokeServer("CloseChest")
        end)
        
        -- Обнуляем цель. Это даст сигнал основному циклу идти дальше
        currentTargetChestId = nil
        return
    end

    -- СИТУАЦИЯ 2: Сервер открыл обычный сундук
    if action == "OpenChest" then
        print("Сервер открыл обычный сундук! Забираю лут...")
        chestOpenedSuccessfully = true
        
        task.wait(0.3)

        -- Забираем все предметы
        for _, item in ipairs(data.items or {}) do
            if item.id then
                print(" -> Забрал:", item.name or "Неизвестно")
                pcall(function()
                    BackpackRemoteFunction:InvokeServer("TakeChestItem", data.chestId, item.id, "MyBackpackInventory")
                end)
                task.wait(0.1)
            end
        end
        
        task.wait(0.2)
        
        -- Закрываем сундук
        pcall(function()
            BackpackRemoteFunction:InvokeServer("CloseChest")
        end)
        
        -- Обнуляем цель
        currentTargetChestId = nil
    end
end)

-- ОСНОВНОЙ ЦИКЛ ФАРМА
print("Запуск фермера (сундуки с паролями будут игнорироваться)...")
for _, chestModel in ipairs(ChestFolder:GetChildren()) do
    
    if chestModel:IsA("Model") and chestModel.Name == "保险箱" then 
        local chestId = chestModel:GetAttribute("ChestId")
        local rootPart = chestModel.PrimaryPart
        
        if chestId and rootPart then
            
            -- Сбрасываем флаги для нового сундука
            currentTargetChestId = chestId
            chestOpenedSuccessfully = false
            skippedPasswordChest = false
            
            -- 1. Телепортируемся
            HumanoidRootPart.CFrame = rootPart.CFrame * CFrame.new(0, 5, 0)
            task.wait(0.5)
            
            -- 2. Ждем реакции сервера (максимум 3 секунды)
            local waitTime = 0
            while currentTargetChestId ~= nil and waitTime < 3 do
                task.wait(0.1)
                waitTime = waitTime + 0.1
            end
            
            -- 3. Анализируем результат
            if skippedPasswordChest then
                -- Просто идем дальше без лишних предупреждений
            elseif not chestOpenedSuccessfully then
                warn("Сундук не открылся (пустой или ошибка дистанции). Пропускаем.")
            end
            
            task.wait(0.5) -- Пауза перед следующим сундуком
        end
    end
end

print("Все сундуки проверены! Фарм завершен.")
